public const uint baseDimension = 10000;
        
        public static void Event_OnPlayerDisconnected(ExtPlayer player)
        {
            try
            {
                var characterData = player.GetCharacterData();
                if (characterData == null) return;
                
                if (player.Dimension >= baseDimension)
                {
                    int unitId = (int)(player.Dimension - baseDimension);
                    if (Units.ContainsKey(unitId))
                    {
                        var unit = Units[unitId];
                        var building = Warehouses.FirstOrDefault(w => w.Id == unit.WarehouseId);
                        if (building != null)
                        {
                            characterData.CurPosition = building.Position;
                        }
                    }
                }
            }
            catch (Exception e)
            {
                Log.Write($"Event_OnPlayerDisconnected Exception: {e.ToString()}");
            }
        }

        public static void Event_OnPlayerSpawn(ExtPlayer player)
        {
            try
            {
                var characterData = player.GetCharacterData();
                if (characterData == null) return;

                if (player.Dimension == 0 && player.Position.DistanceTo(ExitPosition) < 50f)
                {
                    var building = Warehouses.FirstOrDefault();
                    if (building != null)
                    {
                        player.Position = building.Position;
                        Notify.Send(player, NotifyType.Info, NotifyPosition.BottomCenter, "Вы были выведены из склада", 3000); 
                    }
                }
            }
            catch (Exception e)
            {
                Log.Write($"Event_OnPlayerSpawn Exception: {e.ToString()}");
            }
        }


